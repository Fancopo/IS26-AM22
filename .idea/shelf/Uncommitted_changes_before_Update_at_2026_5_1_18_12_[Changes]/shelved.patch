--- a/src/main/java/it/polimi/ingsw/am22/network/client/ObservableServerConnection.java	(revision 6865caf8cd5d60fd8efce1b351c89d8d2c546f82)
+++ b/src/main/java/it/polimi/ingsw/am22/network/client/ObservableServerConnection.java	(date 1777651956466)
@@ -1,12 +1,29 @@
 package it.polimi.ingsw.am22.network.client;
 
+/**
+ * A {@link ServerConnection} that can be observed for incoming server messages
+ * and released deterministically.
+ *
+ * <p>Extending {@link AutoCloseable} lets concrete implementations such as
+ * {@code SocketServerConnection} and {@code RmiServerConnection} be used in
+ * a {@code try-with-resources} block, so the transport is always released
+ * even when an exception escapes the client loop.
+ */
 public interface ObservableServerConnection extends ServerConnection, AutoCloseable {
+
+    /**
+     * Installs the handler that will be notified whenever the server pushes
+     * a message (or the connection is closed). May be {@code null} to clear
+     * a previously installed handler.
+     *
+     * @param handler the handler to install, or {@code null} to detach
+     */
     void setClientUpdateHandler(ClientUpdateHandler handler);
 
+    /**
+     * Releases the underlying transport. Idempotent: repeated calls are
+     * safe and do not throw.
+     */
     @Override
     void close();
 }
