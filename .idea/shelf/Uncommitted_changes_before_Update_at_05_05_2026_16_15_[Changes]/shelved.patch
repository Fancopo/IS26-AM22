  * RMI a gestire le chiamate verso il callback.
  */
 public class RmiServerConnection implements ObservableServerConnection {
+    /** Periodo (ms) tra due heartbeat verso il server. */
+    private static final long HEARTBEAT_PERIOD_MS = 2000L;
+
     private final RemoteGameServer remoteGameServer;
     private final RemoteClientView callback;
+    private final Thread heartbeatThread;
     private volatile ClientUpdateHandler updateHandler;
     private volatile boolean closed;
 
@@ -44,6 +48,42 @@
         this.updateHandler = null;
         this.closed = false;
         this.callback = new ClientCallback();
+        this.heartbeatThread = new Thread(this::heartbeatLoop, "rmi-server-connection-heartbeat");
+        this.heartbeatThread.setDaemon(true);
+        this.heartbeatThread.start();
+    }
+
+    /**
+     * Loop di heartbeat: pinga periodicamente il server. Se il ping fallisce
+     * (server caduto o irraggiungibile) notifica l'handler della disconnessione
+     * e chiude la connessione. Senza questo, RMI non rileverebbe mai la caduta
+     * del server in assenza di chiamate dal client.
+     */
+    private void heartbeatLoop() {
+        while (!closed) {
+            try {
+                Thread.sleep(HEARTBEAT_PERIOD_MS);
+            } catch (InterruptedException ie) {
+                Thread.currentThread().interrupt();
+                return;
+            }
+            if (closed) return;
+            try {
+                remoteGameServer.ping();
+            } catch (RemoteException e) {
+                notifyConnectionClosed(e);
+                return;
+            }
+        }
+    }
+
+    private void notifyConnectionClosed(Throwable cause) {
+        if (closed) return;
+        ClientUpdateHandler handler = updateHandler;
+        close();
+        if (handler != null) {
+            handler.onConnectionClosed(cause);
+        }
     }
 
