+    @Test
+    void testEndGameWinner() {
+        // Manually set some players' PP and food to test winner logic
+        Player p1 = players.get(0);
+        Player p2 = players.get(1);
+        Player p3 = players.get(2);
+
+        p1.addPP(20);
+        p1.addFood(5);
+        p2.addPP(20);
+        p2.addFood(10);
+        p3.addPP(15);
+        p3.addFood(8);
+
+        // Force end game state by setting currentRound to 10 and calling updateRound?
+        // Simpler: create a new EndGameState and call determineWinner directly.
+        // But determineWinner is called by Game when state is EndGameState.
+        // We can just call game.determineWinner() which delegates to current state.
+        // We need to put game in EndGameState.
+        // Since we cannot set private state, we simulate by creating a new Game with end condition?
+        // Alternatively, we can test the logic by instantiating EndGameState and calling its method.
+        // But better: use reflection to set state or just test the method via a custom game instance.
+        // Simpler: we trust that determineWinner works and we test it separately.
+        // However, to keep the test self-contained, we'll set the state via reflection for this single test.
+        try {
+            Field stateField = Game.class.getDeclaredField("currentState");
+            stateField.setAccessible(true);
+            stateField.set(game, new EndGameState());
+        } catch (Exception e) {
+            fail("Could not set state via reflection");
+        }
+
+        Player winner = game.determineWinner();
+        assertEquals(p2, winner);
