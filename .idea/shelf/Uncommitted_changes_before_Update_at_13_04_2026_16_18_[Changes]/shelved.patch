+package it.polimi.ingsw.am22;
+
+import it.polimi.ingsw.am22.event.Event;
+import it.polimi.ingsw.am22.states.BonusCardSelectionState;
+import it.polimi.ingsw.am22.states.EndGameState;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+
+import java.lang.reflect.Field;
+import java.util.ArrayList;
+import java.util.List;
+
+import static org.junit.jupiter.api.Assertions.*;
+
+/**
+ * Test suite for the Game class.
+ * Verifies state transitions, turn order, card picking, and end-of-round updates
+ * using only public methods.
+ */
+class GameTest {
+
+    private Game game;
+    private List<Player> players;
+
+    // Dummy card implementations for testing
+    private static class DummyCard extends Card {
+        public DummyCard(String id, Era era, int minPlayers) {
+            super(id, era, minPlayers);
+        }
+        @Override public void addToTribe(Player player, Tribe tribe) {}
+        @Override public boolean survivesRoundEnd() { return false; }
+    }
+
+    private static class DummyEvent extends Event {
+        public DummyEvent(String id, Era era, int minPlayers) {
+            super(id, era, minPlayers, null, null);
+        }
+        @Override public void onRoundEndTrigger(Game game) {}
+    }
+
+    @BeforeEach
+    void setUp() throws Exception {
+        players = new ArrayList<>();
