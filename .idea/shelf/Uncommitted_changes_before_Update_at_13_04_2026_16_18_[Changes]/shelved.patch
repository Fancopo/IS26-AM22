+    @Test
+    void testRoundEndAndEventResolution() throws Exception {
+        // Simulate a full round to test EventResolutionState and RoundUpdateState
+        game.startMatch();
+        // Place all totems
+        for (int i = 0; i < players.size(); i++) {
+            game.placeTotemOnOffer(players.get(i), game.getBoard().getOfferTrack().get(i));
+        }
+
+        // Force all actions to resolve quickly by providing dummy selections
+        while ("Risoluzione Azioni".equals(game.getCurrentPhaseName())) {
+            Player active = game.getActivePlayer();
+            OfferTile tile = game.getBoard().getOfferTrack().stream()
+                    .filter(t -> t.getOccupiedBy() == active.getTotem())
+                    .findFirst().orElseThrow();
+
+            if (tile.getFoodReward() > 0) {
+                game.pickCards(active, List.of());
+            } else {
+                List<Card> upper = game.getBoard().getUpperRow();
+                List<Card> lower = game.getBoard().getLowerRow();
+                List<Card> selected = new ArrayList<>();
+                int u = tile.getUpperCardsToTake();
+                int l = tile.getLowerCardsToTake();
+                if (u > 0 && upper.size() >= u) selected.addAll(upper.subList(0, u));
+                if (l > 0 && lower.size() >= l) selected.addAll(lower.subList(0, l));
+                game.pickCards(active, selected);
+            }
+        }
+
+        // After all actions, phase should be either EventResolutionState or BonusCardSelectionState
+        String phase = game.getCurrentPhaseName();
+        assertTrue(phase.equals("Risoluzione Eventi") || phase.equals("Selezione Carta Bonus") ||
+                phase.equals("Fine Round / Pulizia"));
+
+        // If we are in EventResolutionState, call resolveEvents
+        if ("Risoluzione Eventi".equals(phase)) {
+            game.resolveEvents();
+            // After resolveEvents, phase becomes RoundUpdateState
+            assertEquals("Fine Round / Pulizia", game.getCurrentPhaseName());
+        } else if ("Selezione Carta Bonus".equals(phase)) {
+            // Simulate picking a bonus card (if any)
+            Card bonus = game.getBoard().getUpperRow().isEmpty() ? null : game.getBoard().getUpperRow().get(0);
+            if (bonus != null) {
+                game.pickBonusCard(game.getActivePlayer(), bonus);
+                // After bonus, should go to EventResolutionState then RoundUpdateState
+                assertEquals("Risoluzione Eventi", game.getCurrentPhaseName());
+                game.resolveEvents();
+                assertEquals("Fine Round / Pulizia", game.getCurrentPhaseName());
+            }
+        }
+
+        // Now call updateRound
+        game.updateRound();
+
+        // Round should be incremented
+        assertEquals(2, game.getCurrentRound());
+        // Phase should be back to TotemPlacementState (unless game ended)
+        assertTrue(game.getCurrentPhaseName().equals("Piazzamento Totem") ||
+                game.getCurrentPhaseName().equals("Fine Partita"));
+    }
