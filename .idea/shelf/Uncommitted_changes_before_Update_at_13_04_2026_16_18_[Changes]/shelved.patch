+    @Test
+    void testActionResolutionWithFoodTile() {
+        // Prepare game: after placement, we need to simulate a complete round
+        game.startMatch();
+        // Place all totems (simplify by forcing order)
+        List<OfferTile> tiles = game.getBoard().getOfferTrack();
+        for (int i = 0; i < players.size(); i++) {
+            Player p = players.get(i);
+            OfferTile tile = tiles.get(i);
+            game.placeTotemOnOffer(p, tile);
+        }
+
+        // Now we are in ActionResolutionState
+        assertEquals("Risoluzione Azioni", game.getCurrentPhaseName());
+
+        // Simulate picking cards for the first player (who is on a tile, e.g. tile B)
+        Player active = game.getActivePlayer();
+        OfferTile currentTile = game.getBoard().getOfferTrack().stream()
+                .filter(t -> t.getOccupiedBy() == active.getTotem())
+                .findFirst().orElseThrow();
+
+        // For a tile with food reward (e.g., tile A), selectedCards must be empty
+        if (currentTile.getFoodReward() > 0) {
+            game.pickCards(active, List.of());
+            // Food should be added
+            assertTrue(active.getFood() > 0);
+        } else {
+            // For normal tiles, we need to pick correct number of cards from rows
+            List<Card> upper = game.getBoard().getUpperRow();
+            List<Card> lower = game.getBoard().getLowerRow();
+            int upperToTake = currentTile.getUpperCardsToTake();
+            int lowerToTake = currentTile.getLowerCardsToTake();
+
+            if (upperToTake + lowerToTake > 0) {
+                List<Card> selected = new ArrayList<>();
+                if (upperToTake > 0 && upper.size() >= upperToTake) {
+                    selected.addAll(upper.subList(0, upperToTake));
+                }
+                if (lowerToTake > 0 && lower.size() >= lowerToTake) {
+                    selected.addAll(lower.subList(0, lowerToTake));
+                }
+                game.pickCards(active, selected);
+            } else {
+                game.pickCards(active, List.of());
+            }
+        }
+
+        // After resolution, totem should be moved to turn order tile
+        assertNotNull(active.getTotem().getCurrentSlot());
+    }
